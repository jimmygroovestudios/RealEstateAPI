generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  role          Role     @default(BUYER)
  firstName     String?
  lastName      String?
  phone         String?
  avatar        String?
  isVerified    Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  licenseNumber String?
  agencyName    String?
  bio           String?  @db.Text
  
  properties      Property[]         @relation("AgentProperties")
  favorites       FavoriteProperty[]
  savedSearches   SavedSearch[]
  viewHistory     ViewHistory[]
  leadsReceived   Lead[]             @relation("AgentLeads")
  leadsSent       Lead[]             @relation("BuyerLeads")
  leadNotes       LeadNote[]
  showingsAsBuyer Showing[]          @relation("BuyerShowings")
  showingsAsAgent Showing[]          @relation("AgentShowings")
  reviewsGiven    AgentReview[]      @relation("ReviewerReviews")
  reviewsReceived AgentReview[]      @relation("AgentReviews")
  
  @@index([email])
  @@index([role])
}

model Property {
  id          String         @id @default(cuid())
  title       String
  description String         @db.Text
  price       Decimal        @db.Decimal(12, 2)
  bedrooms    Int
  bathrooms   Decimal        @db.Decimal(3, 1)
  sqft        Int
  lotSize     Int?
  yearBuilt   Int?
  propertyType PropertyType  @default(HOUSE)
  
  address     String
  city        String
  state       String
  zipCode     String
  latitude    Decimal        @db.Decimal(10, 8)
  longitude   Decimal        @db.Decimal(11, 8)
  
  status      PropertyStatus @default(ACTIVE)
  
  // Enhanced fields (Zillow/Redfin inspired)
  mlsNumber       String?   @unique
  virtualTourUrl  String?
  openHouseDate   DateTime?
  daysOnMarket    Int       @default(0)
  pricePerSqft    Decimal?  @db.Decimal(10, 2)
  hoaFee          Decimal?  @db.Decimal(10, 2)
  parkingSpaces   Int?
  garage          Boolean   @default(false)
  pool            Boolean   @default(false)
  features        String[]
  estimatedValue  Decimal?  @db.Decimal(12, 2)
  
  agentId     String
  agent       User           @relation("AgentProperties", fields: [agentId], references: [id])
  
  images       PropertyImage[]
  favorites    FavoriteProperty[]
  viewHistory  ViewHistory[]
  leads        Lead[]
  priceHistory PriceHistory[]
  showings     Showing[]
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  @@index([agentId])
  @@index([status])
  @@index([city, state])
  @@index([price, bedrooms, bathrooms])
  @@index([latitude, longitude])
  @@index([mlsNumber])
  @@index([zipCode])
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  isPrimary  Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  @@index([propertyId])
}

model FavoriteProperty {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  @@unique([userId, propertyId])
  @@index([userId])
}

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  name      String
  criteria  Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

model ViewHistory {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  viewedAt   DateTime @default(now())
  sessionId  String?
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([propertyId])
  @@index([viewedAt])
}

model Lead {
  id           String     @id @default(cuid())
  propertyId   String
  buyerId      String
  agentId      String
  status       LeadStatus @default(NEW)
  message      String?    @db.Text
  qualityScore Int        @default(0)
  contactedAt  DateTime?
  respondedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  
  property     Property   @relation(fields: [propertyId], references: [id])
  buyer        User       @relation("BuyerLeads", fields: [buyerId], references: [id])
  agent        User       @relation("AgentLeads", fields: [agentId], references: [id])
  notes        LeadNote[]
  
  @@index([agentId, status])
  @@index([buyerId])
  @@index([createdAt])
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())
  
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
  
  @@index([leadId])
}

enum Role {
  BUYER
  AGENT
  ADMIN
}

enum PropertyStatus {
  ACTIVE
  PENDING
  SOLD
  OFF_MARKET
}

enum PropertyType {
  HOUSE
  CONDO
  TOWNHOUSE
  APARTMENT
  LAND
  MULTI_FAMILY
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  SHOWING_SCHEDULED
  OFFER_MADE
  CLOSED_WON
  CLOSED_LOST
  UNRESPONSIVE
}

// ============================================
// NEW MODELS - Zillow/Redfin Inspired Features
// ============================================

model PriceHistory {
  id         String   @id @default(cuid())
  propertyId String
  price      Decimal  @db.Decimal(12, 2)
  date       DateTime
  eventType  PriceEventType
  
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  @@index([propertyId])
  @@index([date])
}

enum PriceEventType {
  LISTED
  PRICE_INCREASE
  PRICE_DECREASE
  SOLD
  RELISTED
}

model Showing {
  id           String        @id @default(cuid())
  propertyId   String
  buyerId      String
  agentId      String
  requestedAt  DateTime      @default(now())
  scheduledAt  DateTime?
  status       ShowingStatus @default(REQUESTED)
  notes        String?       @db.Text
  feedback     String?       @db.Text
  rating       Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  
  property     Property      @relation(fields: [propertyId], references: [id])
  buyer        User          @relation("BuyerShowings", fields: [buyerId], references: [id])
  agent        User          @relation("AgentShowings", fields: [agentId], references: [id])
  
  @@index([propertyId])
  @@index([buyerId])
  @@index([agentId])
  @@index([status])
  @@index([scheduledAt])
}

enum ShowingStatus {
  REQUESTED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Neighborhood {
  id              String   @id @default(cuid())
  zipCode         String   @unique
  name            String
  city            String
  state           String
  county          String?
  medianPrice     Decimal? @db.Decimal(12, 2)
  medianRent      Decimal? @db.Decimal(10, 2)
  walkScore       Int?
  transitScore    Int?
  bikeScore       Int?
  crimeScore      Int?
  schoolRating    Decimal? @db.Decimal(3, 1)
  population      Int?
  medianIncome    Decimal? @db.Decimal(12, 2)
  medianAge       Decimal? @db.Decimal(4, 1)
  description     String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  marketTrends    MarketTrend[]
  
  @@index([city, state])
}

model MarketTrend {
  id              String   @id @default(cuid())
  neighborhoodId  String
  month           DateTime
  medianPrice     Decimal  @db.Decimal(12, 2)
  avgPricePerSqft Decimal? @db.Decimal(10, 2)
  inventory       Int
  newListings     Int?
  soldCount       Int?
  daysOnMarket    Int?
  priceChange     Decimal? @db.Decimal(5, 2)
  createdAt       DateTime @default(now())
  
  neighborhood    Neighborhood @relation(fields: [neighborhoodId], references: [id], onDelete: Cascade)
  
  @@unique([neighborhoodId, month])
  @@index([neighborhoodId])
  @@index([month])
}

model AgentReview {
  id          String   @id @default(cuid())
  agentId     String
  reviewerId  String
  rating      Int
  title       String?
  content     String   @db.Text
  wouldRecommend Boolean @default(true)
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  agent       User     @relation("AgentReviews", fields: [agentId], references: [id])
  reviewer    User     @relation("ReviewerReviews", fields: [reviewerId], references: [id])
  
  @@index([agentId])
  @@index([rating])
}
